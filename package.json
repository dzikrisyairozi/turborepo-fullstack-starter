{
  "name": "monorepo-fullstack-starter",
  "private": true,
  "author": {
    "name": "Dzikri Syairozi",
    "email": "dzikrisyairozi@gmail.com",
    "url": "https://github.com/dzikrisyairozi"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dzikrisyairozi/monorepo-fullstack-starter"
  },
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:check": "turbo run lint:check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,js,jsx,css,scss,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,js,jsx,css,scss,yaml,yml}\"",
    "type-check": "turbo run type-check",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "clean": "turbo run clean",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "turbo run dev --filter=api",
    "dev:docs": "turbo run dev --filter=docs",
    "dev:dashboard": "turbo run dev --filter=@repo/dashboard",
    "build:web": "turbo run build --filter=web",
    "build:api": "turbo run build --filter=api",
    "build:docs": "turbo run build --filter=docs",
    "build:dashboard": "turbo run build --filter=@repo/dashboard",
    "db:generate": "turbo run db:generate --filter=@repo/db",
    "db:push": "turbo run db:push --filter=@repo/db",
    "db:migrate": "turbo run db:migrate --filter=@repo/db",
    "db:studio": "turbo run db:studio --filter=@repo/db",
    "db:seed": "turbo run db:seed --filter=@repo/db",
    "db:reset": "turbo run db:reset --filter=@repo/db",
    "prepare": "husky install",
    "commitlint": "commitlint --edit",
    "check-all": "pnpm run type-check && pnpm run lint && pnpm run format:check"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.4",
    "@types/node": "^25.3.3",
    "es-abstract": "^1.24.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "turbo": "^2.8.12",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.3",
      "@types/react-dom": "18.3.0"
    }
  }
}
